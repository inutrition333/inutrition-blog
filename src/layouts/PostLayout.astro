---
/**
 * PostLayout — 單篇文章頁外殼
 *
 * 把 BaseLayout 包好，再依 hero / TOC / 內文 / 分享 / CTA / 相關文章 順序組裝。
 * 所有元件都從 src/components 搬來；資料從 [slug].astro 那邊傳進來。
 */

import BaseLayout from './BaseLayout.astro';
import BrandBar from '../components/BrandBar.astro';
import Hero from '../components/Hero.astro';
import TOC, { type TocItem } from '../components/TOC.astro';
import ShareBar from '../components/ShareBar.astro';
import EndCTA from '../components/EndCTA.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import Footer from '../components/Footer.astro';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  /** 當前這篇文章 entry */
  post: CollectionEntry<'posts'>;
  /** 從文章 markdown 自動抽出的目錄項目（H2） */
  tocItems: TocItem[];
  /** 相關文章（兩篇） */
  relatedPosts: CollectionEntry<'posts'>[];
}

const { post, tocItems, relatedPosts } = Astro.props;
const { title, category, publishDate, readTime, excerpt, heroImage, campaign } = post.data;

const siteUrl = Astro.site?.toString() ?? 'https://blog.inutrition.com.tw';
const postUrl = new URL(`/posts/${post.slug}`, siteUrl).toString();
const postSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: excerpt,
  url: postUrl,
  datePublished: publishDate,
  dateModified: publishDate,
  image: heroImage ? new URL(heroImage, siteUrl).toString() : new URL('/og-default.jpg', siteUrl).toString(),
  inLanguage: 'zh-TW',
  author: {
    '@type': 'Person',
    name: '黃君聖Sunny營養師',
    url: new URL('/about', siteUrl).toString(),
  },
  publisher: {
    '@type': 'Organization',
    name: '愛營養 iNutrition',
    url: 'https://www.inutrition.com.tw',
    logo: {
      '@type': 'ImageObject',
      url: new URL('/favicon.svg', siteUrl).toString(),
    },
  },
  articleSection: category,
  timeRequired: `PT${readTime}M`,
};
---

<BaseLayout
  title={title}
  description={excerpt}
  ogImage={heroImage}
>
  <script type="application/ld+json" set:html={JSON.stringify(postSchema)} />
  <!-- 滾動進度條（建置指令第 524-534 行） -->
  <div class="progress-bar" id="progressBar"></div>

  <BrandBar campaign={campaign} />

  <Hero
    category={category}
    title={title}
    publishDate={publishDate}
    readTime={readTime}
  />

  <TOC items={tocItems} />

  <article class="article-body">
    <slot />

    <ShareBar title={title} />

    <div class="post-author-block">
      <div class="post-author-avatar-wrap">
        <img
          class="post-author-avatar"
          src="/images/sunny-avatar.jpg"
          alt="黃君聖Sunny營養師"
          width="56"
          height="56"
          loading="lazy"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        />
        <div class="post-author-fallback" aria-hidden="true">S</div>
      </div>
      <div class="post-author-info">
        <p class="post-author-label">本文作者</p>
        <a class="post-author-name" href="/about">黃君聖Sunny營養師</a>
        <p class="post-author-desc">臺灣執照營養師・美國ACE-CPT國際私人教練・愛營養iNutrition品牌創辦人</p>
      </div>
    </div>

    <EndCTA campaign={campaign} />
  </article>

  <RelatedPosts posts={relatedPosts} />

  <Footer />

  <!-- 滾動進度條 client-side script（建置指令第 527-533 行） -->
  <script is:inline>
    (function () {
      var bar = document.getElementById('progressBar');
      if (!bar) return;
      function update() {
        var doc = document.documentElement;
        var scrollTop = doc.scrollTop || document.body.scrollTop;
        var scrollHeight = doc.scrollHeight - doc.clientHeight;
        var progress = scrollHeight > 0 ? (scrollTop / scrollHeight) * 100 : 0;
        bar.style.width = progress + '%';
      }
      update();
      window.addEventListener('scroll', update, { passive: true });
    })();
  </script>
</BaseLayout>

<style>
  .post-author-block {
    display: flex;
    align-items: center;
    gap: 16px;
    background: var(--color-highlight);
    border-radius: 12px;
    padding: 18px 20px;
    margin: 32px 0 0;
  }
  .post-author-avatar-wrap {
    position: relative;
    width: 56px;
    height: 56px;
    flex-shrink: 0;
  }
  .post-author-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    background: var(--color-accent-light);
  }
  .post-author-fallback {
    display: none;
    align-items: center;
    justify-content: center;
    position: absolute;
    inset: 0;
    background: var(--color-accent);
    color: #fff;
    border-radius: 50%;
    font-size: 22px;
    font-weight: 700;
    font-family: var(--font-heading);
  }
  .post-author-label {
    font-size: 11px;
    color: var(--color-text-light);
    letter-spacing: 1px;
    margin: 0 0 2px;
  }
  .post-author-name {
    display: block;
    font-size: 16px;
    font-weight: 700;
    color: var(--color-accent-dark);
    text-decoration: none;
    margin-bottom: 4px;
  }
  .post-author-name:hover {
    text-decoration: underline;
  }
  .post-author-desc {
    font-size: 13px;
    color: var(--color-text-light);
    line-height: 1.6;
    margin: 0;
  }
</style>
