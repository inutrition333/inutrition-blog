---
import { CATEGORIES } from '../content/config';
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>快速發文 — 愛營養</title>
  </head>
  <body>
    <main class="shell">
      <header class="page-head">
        <h1>快速發文</h1>
        <p class="hint">適合已經寫好的稿子。送出後約 1 分鐘自動上線。</p>
      </header>

      <!-- 密碼登入畫面 -->
      <section id="login" class="card">
        <label class="field">
          <span class="label">管理員密碼</span>
          <input id="password" type="password" autocomplete="current-password" placeholder="請輸入密碼" />
        </label>
        <button id="login-btn" class="primary">進入發文</button>
        <p id="login-err" class="err" hidden></p>
      </section>

      <!-- 草稿提示橫幅（有未完成草稿才顯示） -->
      <div id="draft-banner" class="draft-banner" hidden>
        📝 你有一篇未完成的草稿，是否繼續？
        <button id="restore-btn" class="inline-btn">繼續上次的草稿</button>
        <button id="discard-btn" class="inline-btn danger-text">捨棄</button>
      </div>

      <!-- 發文表單 -->
      <section id="form" class="card" hidden>
        <label class="field">
          <span class="label">文章標題 <em>*</em></span>
          <input id="title" type="text" placeholder="例如：桑葉萃取是什麼？" required />
        </label>

        <div class="row">
          <label class="field">
            <span class="label">分類 <em>*</em></span>
            <select id="category" required>
              {CATEGORIES.map((c) => <option value={c}>{c}</option>)}
            </select>
          </label>

          <label class="field">
            <span class="label">發布日期</span>
            <input id="publishDate" type="date" />
          </label>

          <label class="field narrow">
            <span class="label">閱讀分鐘</span>
            <input id="readTime" type="number" min="1" max="30" value="6" />
          </label>
        </div>

        <label class="field">
          <span class="label">文章摘要 <em>*</em></span>
          <textarea id="excerpt" rows="2" placeholder="一兩句話，首頁列表會顯示"></textarea>
        </label>

        <details class="advanced">
          <summary>顯示進階欄位（可略過）</summary>
          <label class="field">
            <span class="label">活動識別碼 campaign</span>
            <input id="campaign" type="text" placeholder="例如：桑葉萃取_202604" />
            <span class="sublabel">留空會自動用「主題_年月」格式。</span>
          </label>
          <label class="field">
            <span class="label">檔名（URL slug）</span>
            <input id="slug" type="text" placeholder="例如：mulberry-leaf-guide" />
            <span class="sublabel">英文小寫+連字號。留空會自動產生。</span>
          </label>
          <label class="field">
            <span class="label">主圖路徑</span>
            <input id="heroImage" type="text" placeholder="/images/xxx.jpg" />
            <span class="sublabel">先上傳圖到後台再把路徑貼過來；可留空。</span>
          </label>
          <label class="check">
            <input id="draft" type="checkbox" />
            存成草稿（不公開、只存在 GitHub）
          </label>
        </details>

        <div class="body-section">
          <div class="tab-bar">
            <button type="button" id="tab-edit" class="tab tab-active">✏️ 編輯</button>
            <button type="button" id="tab-preview" class="tab">👁 預覽</button>
          </div>
          <div id="edit-col">
            <span class="pane-label">✏️ 編輯</span>
            <div id="edit-pane">
              <label class="field" style="margin-bottom:0">
                <span class="label">文章內文（Markdown） <em>*</em></span>
                <textarea id="body" rows="18" placeholder="在這裡貼整段 markdown。支援 :::product、:::sunny、:::related 區塊。"></textarea>
              </label>
            </div>
          </div>
          <div id="preview-col" hidden>
            <span class="pane-label">👁 預覽</span>
            <div id="preview-pane" class="preview-pane"></div>
          </div>
        </div>

        <div class="action-row">
          <button id="publish-btn" class="primary">送出發文</button>
        </div>
        <p id="publish-msg" class="msg" hidden></p>

        <!-- 刪除文章 -->
        <details class="danger-zone">
          <summary>🗑 刪除已發布的文章</summary>
          <p class="sublabel" style="margin-bottom:10px;">輸入文章的檔名（slug），例如網址是 <code>/posts/bitter-melon-guide</code> 就填 <code>bitter-melon-guide</code>。</p>
          <label class="field">
            <span class="label">文章檔名（slug）</span>
            <input id="delete-slug" type="text" placeholder="例如：bitter-melon-guide" />
          </label>
          <button id="delete-btn" class="danger-btn">確認刪除</button>
          <p id="delete-msg" class="msg" hidden></p>
        </details>
      </section>

      <footer class="foot">
        <small>若發文失敗，請先把整段內文複製下來保險；再試一次仍失敗就走 <a href="/admin/">完整後台</a>。</small>
      </footer>
    </main>

    <style>
      :root {
        --bg: #faf7f2;
        --card: #fff;
        --text: #2a2a2a;
        --text-light: #666;
        --border: #e4ded3;
        --accent: #4a7c3a;
        --accent-dark: #3a5f2c;
        --err: #b94a4a;
        --ok: #2f7a3a;
        --danger: #c0392b;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: -apple-system, BlinkMacSystemFont, 'Noto Sans TC', 'PingFang TC', sans-serif;
        line-height: 1.6;
      }
      .shell { max-width: 820px; margin: 0 auto; padding: 32px 20px 60px; }
      .page-head h1 { font-size: 28px; margin: 0 0 6px; }
      .hint { margin: 0 0 24px; color: var(--text-light); font-size: 14px; }
      .card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 24px;
        margin-bottom: 18px;
      }
      .draft-banner {
        background: #fff8e6;
        border: 1px solid #f0d080;
        border-radius: 10px;
        padding: 12px 16px;
        margin-bottom: 14px;
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
      }
      .inline-btn {
        background: none;
        border: 1px solid currentColor;
        border-radius: 6px;
        padding: 4px 10px;
        font-size: 13px;
        cursor: pointer;
        font-family: inherit;
        color: var(--accent-dark);
      }
      .danger-text { color: var(--err); }
      .field { display: block; margin-bottom: 16px; }
      .label { display: block; font-size: 14px; font-weight: 600; margin-bottom: 6px; }
      .label em { color: var(--err); font-style: normal; margin-left: 2px; }
      .sublabel { display: block; font-size: 12px; color: var(--text-light); margin-top: 4px; }
      input[type="text"], input[type="password"], input[type="number"], input[type="date"], select, textarea {
        width: 100%;
        padding: 10px 12px;
        font-size: 15px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: #fff;
        font-family: inherit;
      }
      textarea {
        font-family: ui-monospace, 'SF Mono', Menlo, monospace;
        font-size: 14px;
        line-height: 1.6;
        resize: vertical;
      }
      input:focus, select:focus, textarea:focus { outline: 2px solid var(--accent); outline-offset: -1px; }
      .row { display: grid; grid-template-columns: 1.4fr 1fr 0.8fr; gap: 12px; }
      .row .field { margin-bottom: 16px; }
      @media (max-width: 560px) { .row { grid-template-columns: 1fr; } }
      .advanced {
        border: 1px dashed var(--border);
        border-radius: 8px;
        padding: 10px 14px;
        margin-bottom: 16px;
      }
      .advanced summary { cursor: pointer; font-size: 14px; color: var(--text-light); }
      .advanced[open] summary { margin-bottom: 12px; }
      .check { display: flex; gap: 8px; align-items: center; font-size: 14px; margin-top: 8px; }
      button.primary {
        background: var(--accent);
        color: #fff;
        border: none;
        padding: 12px 24px;
        font-size: 15px;
        font-weight: 600;
        border-radius: 8px;
        cursor: pointer;
        font-family: inherit;
      }
      button.primary:hover { background: var(--accent-dark); }
      button.primary:disabled { opacity: 0.5; cursor: wait; }
      .action-row { margin-bottom: 4px; }
      .danger-zone {
        border: 1px dashed #e0a0a0;
        border-radius: 8px;
        padding: 10px 14px;
        margin-top: 20px;
        background: #fff8f8;
      }
      .danger-zone summary { cursor: pointer; font-size: 14px; color: var(--err); }
      .danger-zone[open] summary { margin-bottom: 10px; }
      .danger-btn {
        background: var(--danger);
        color: #fff;
        border: none;
        padding: 10px 20px;
        font-size: 14px;
        font-weight: 600;
        border-radius: 8px;
        cursor: pointer;
        font-family: inherit;
      }
      .danger-btn:hover { background: #a93226; }
      .danger-btn:disabled { opacity: 0.5; cursor: wait; }
      .err { color: var(--err); font-size: 14px; margin: 10px 0 0; }
      .msg { font-size: 14px; margin: 14px 0 0; padding: 10px 14px; border-radius: 8px; }
      .msg.ok { background: #eaf5ea; color: var(--ok); border: 1px solid #cde6cd; }
      .msg.err { background: #fbecec; color: var(--err); border: 1px solid #f1cfcf; }
      .foot { margin-top: 24px; text-align: center; color: var(--text-light); }
      .foot a { color: var(--accent-dark); }
      code { background: #f0ece6; padding: 1px 5px; border-radius: 4px; font-size: 13px; }

      /* ===== 預覽 tab ===== */
      .body-section { margin-bottom: 16px; }
      .tab-bar { display: flex; gap: 2px; }
      .tab {
        background: #f0ece6; border: 1px solid var(--border); border-bottom: none;
        padding: 8px 18px; font-size: 14px; cursor: pointer;
        border-radius: 8px 8px 0 0; font-family: inherit; color: var(--text-light);
      }
      .tab-active { background: #fff; color: var(--text); font-weight: 600; }
      #edit-pane textarea {
        border-radius: 0 8px 8px 8px;
      }
      .preview-pane {
        border: 1px solid var(--border); border-radius: 0 8px 8px 8px;
        min-height: 340px; padding: 28px 32px;
        background: #fff; overflow-y: auto;
        font-family: -apple-system, BlinkMacSystemFont, 'Noto Sans TC', 'PingFang TC', sans-serif;
        font-size: 17px; line-height: 2.0; color: #2E2820;
      }
      .preview-pane p { margin-bottom: 20px; }
      .preview-pane h2 {
        font-size: 22px; font-weight: 700; color: #2E2820;
        margin-top: 48px; margin-bottom: 18px;
        padding-left: 14px; border-left: 4px solid #5E8A50; line-height: 1.5;
      }
      .preview-pane h2:first-child { margin-top: 0; }
      .preview-pane h3 {
        font-size: 18px; font-weight: 700; color: #B07D4F;
        margin-top: 36px; margin-bottom: 14px;
      }
      .preview-pane strong { font-weight: 700; }
      .preview-pane a { color: #4A7340; text-underline-offset: 3px; }
      .preview-pane ul, .preview-pane ol { padding-left: 24px; margin-bottom: 20px; }
      .preview-pane li { margin-bottom: 6px; }
      /* sunny-note */
      .preview-pane .sunny-note {
        background: #E6EFE3; border-radius: 14px;
        padding: 22px 22px 22px 62px; margin: 32px 0;
        position: relative; font-size: 16px;
      }
      .preview-pane .sunny-note::before {
        content: '🌿'; position: absolute; left: 18px; top: 20px; font-size: 26px;
      }
      .preview-pane .note-title {
        font-weight: 700; color: #4A7340; margin-bottom: 8px; font-size: 15px;
      }
      .preview-pane .sunny-note p { margin-bottom: 8px; }
      .preview-pane .sunny-note p:last-child { margin-bottom: 0; }
      /* product card */
      .preview-pane .product-card {
        background: #fff; border-radius: 14px;
        box-shadow: 0 2px 18px rgba(46,40,32,0.08);
        margin: 36px 0; overflow: hidden;
      }
      .preview-pane .product-card-inner { display: flex; align-items: stretch; }
      .preview-pane .product-card-image {
        flex: 0 0 160px; min-height: 160px;
        background: linear-gradient(135deg, #E6EFE3, #EDDCC8);
        display: flex; align-items: center; justify-content: center; overflow: hidden;
      }
      .preview-pane .product-card-image img { width: 100%; height: 100%; object-fit: cover; display: block; }
      .preview-pane .product-card-content { flex: 1; padding: 20px 24px; display: flex; flex-direction: column; }
      .preview-pane .product-card-tag {
        display: inline-block; font-size: 11px; font-weight: 700;
        color: #4A7340; background: #E6EFE3;
        padding: 3px 10px; border-radius: 4px; margin-bottom: 8px; align-self: flex-start;
      }
      .preview-pane .product-card-content h4 { font-size: 16px; font-weight: 700; margin-bottom: 6px; color: #2E2820; }
      .preview-pane .product-card-content p { font-size: 14px; color: #5C5347; margin-bottom: 12px; line-height: 1.7; flex: 1; }
      .preview-pane .product-card-cta {
        display: inline-block; background: #3D6233; color: #fff !important;
        padding: 10px 22px; border-radius: 8px; text-decoration: none !important;
        font-size: 14px; font-weight: 700; align-self: flex-start;
      }
      /* related link */
      .preview-pane .related-link {
        display: block; background: #F5EFDF; border-radius: 10px;
        padding: 16px 20px; margin: 24px 0; text-decoration: none !important;
      }
      .preview-pane .related-label {
        display: block; font-size: 11px; color: #B07D4F;
        font-weight: 700; margin-bottom: 4px; letter-spacing: 1px;
      }
      .preview-pane .related-title {
        font-size: 15px; font-weight: 500; color: #4A7340;
        display: flex; justify-content: space-between; align-items: center;
      }
      .preview-pane .related-title::after { content: '→'; }

      /* ===== 桌面分割預覽 ===== */
      @media (min-width: 700px) {
        .shell { max-width: 1200px; }
        .tab-bar { display: none; }
        .body-section {
          display: flex;
          gap: 20px;
          align-items: flex-start;
          margin-bottom: 16px;
        }
        #edit-col {
          flex: 1;
          min-width: 0;
        }
        #preview-col {
          flex: 1;
          min-width: 0;
          display: block !important;
        }
        #edit-pane textarea {
          border-radius: 8px;
          min-height: 480px;
        }
        .preview-pane {
          min-height: 480px;
          border-radius: 8px;
        }
        .pane-label {
          display: block;
          font-size: 13px;
          font-weight: 600;
          color: var(--text-light);
          margin-bottom: 6px;
        }
      }
      @media (max-width: 699px) {
        .pane-label { display: none; }
      }
    </style>

    <script src="https://unpkg.com/marked/marked.min.js"></script>
    <script is:inline>
      document.getElementById('publishDate').valueAsDate = new Date();

      const PW_KEY = 'inutrition_publish_pw';
      const DRAFT_KEY = 'inutrition_write_draft';
      const DRAFT_FIELDS = ['title', 'category', 'publishDate', 'readTime', 'excerpt', 'campaign', 'slug', 'heroImage', 'body'];

      const loginCard = document.getElementById('login');
      const formCard  = document.getElementById('form');
      const pwInput   = document.getElementById('password');
      const loginBtn  = document.getElementById('login-btn');
      const loginErr  = document.getElementById('login-err');
      const draftBanner = document.getElementById('draft-banner');

      // 草稿按鈕先在頁面載入時就綁好，不依賴 checkDraftBanner 的執行時機
      let pendingDraftData = null;
      document.getElementById('restore-btn').addEventListener('click', () => {
        if (pendingDraftData) { restoreDraft(pendingDraftData); pendingDraftData = null; }
        draftBanner.hidden = true;
      });
      document.getElementById('discard-btn').addEventListener('click', () => {
        clearDraft(); pendingDraftData = null; draftBanner.hidden = true;
      });

      const saved = sessionStorage.getItem(PW_KEY);
      if (saved) { pwInput.value = saved; showForm(); }

      loginBtn.addEventListener('click', async () => {
        const pw = pwInput.value.trim();
        if (!pw) { showLoginErr('請輸入密碼'); return; }
        try {
          loginBtn.disabled = true;
          const res = await fetch('/api/publish', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ password: pw, ping: true }),
          });
          if (res.status === 401) { showLoginErr('密碼錯誤'); loginBtn.disabled = false; return; }
          if (!res.ok) {
            const d = await res.json().catch(() => ({}));
            showLoginErr(d.error || '登入失敗，請稍後再試');
            loginBtn.disabled = false; return;
          }
          sessionStorage.setItem(PW_KEY, pw);
          showForm();
          loginBtn.disabled = false;
        } catch (e) { showLoginErr('連線失敗：' + e.message); loginBtn.disabled = false; }
      });

      pwInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') loginBtn.click(); });

      function showLoginErr(msg) { loginErr.textContent = msg; loginErr.hidden = false; }

      function showForm() {
        loginCard.hidden = true;
        formCard.hidden = false;
        checkDraftBanner();
        // 桌面版：讓 preview-col 隨 CSS 分割顯示，初始渲染一次
        if (window.matchMedia('(min-width: 700px)').matches) {
          document.getElementById('preview-col').removeAttribute('hidden');
          renderPreview();
        }
      }

      // ===== localStorage 草稿 =====
      function saveDraft() {
        const data = {};
        DRAFT_FIELDS.forEach((id) => {
          const el = document.getElementById(id);
          data[id] = el ? el.value : '';
        });
        data.draft = document.getElementById('draft').checked;
        localStorage.setItem(DRAFT_KEY, JSON.stringify(data));
      }

      function restoreDraft(data) {
        DRAFT_FIELDS.forEach((id) => {
          const el = document.getElementById(id);
          if (el && data[id] !== undefined) el.value = data[id];
        });
        document.getElementById('draft').checked = !!data.draft;
      }

      function clearDraft() { localStorage.removeItem(DRAFT_KEY); }

      function checkDraftBanner() {
        const raw = localStorage.getItem(DRAFT_KEY);
        if (!raw) return;
        try {
          const data = JSON.parse(raw);
          if (['title', 'excerpt', 'body'].some((id) => data[id] && data[id].trim())) {
            pendingDraftData = data;
            draftBanner.hidden = false;
          } else {
            clearDraft();
          }
        } catch (_) { clearDraft(); }
      }

      // 自動儲存：throttled，每 3 秒最多儲存一次
      let saveTimer = null;
      function scheduleSave() {
        if (saveTimer) return;
        saveTimer = setTimeout(() => { saveDraft(); saveTimer = null; }, 3000);
      }

      DRAFT_FIELDS.forEach((id) => {
        const el = document.getElementById(id);
        if (el) el.addEventListener('input', scheduleSave);
      });
      document.getElementById('draft').addEventListener('change', scheduleSave);

      // ===== 發文 =====
      const publishBtn = document.getElementById('publish-btn');
      const publishMsg = document.getElementById('publish-msg');

      publishBtn.addEventListener('click', async () => {
        publishMsg.hidden = true;
        publishMsg.className = 'msg';

        const payload = {
          password: sessionStorage.getItem(PW_KEY) || pwInput.value.trim(),
          title:       document.getElementById('title').value.trim(),
          category:    document.getElementById('category').value,
          publishDate: document.getElementById('publishDate').value,
          readTime:    parseInt(document.getElementById('readTime').value || '6', 10),
          excerpt:     document.getElementById('excerpt').value.trim(),
          campaign:    document.getElementById('campaign').value.trim(),
          slug:        document.getElementById('slug').value.trim(),
          heroImage:   document.getElementById('heroImage').value.trim(),
          draft:       document.getElementById('draft').checked,
          body:        document.getElementById('body').value,
        };

        const missing = [];
        if (!payload.title) missing.push('標題');
        if (!payload.excerpt) missing.push('摘要');
        if (!payload.body.trim()) missing.push('內文');
        if (missing.length) { showMsg('err', '還有必填沒填：' + missing.join('、')); return; }

        try {
          publishBtn.disabled = true;
          publishBtn.textContent = '送出中…';
          const res = await fetch('/api/publish', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok) { showMsg('err', data.error || `送出失敗（HTTP ${res.status}）`); return; }
          showMsg('ok', `已送出 ✅ 約 1 分鐘後自動上線。檔名：${data.path}。`);
          ['title', 'excerpt', 'campaign', 'slug', 'heroImage', 'body'].forEach((id) => {
            document.getElementById(id).value = '';
          });
          document.getElementById('draft').checked = false;
          clearDraft();
          draftBanner.hidden = true;
        } catch (e) {
          showMsg('err', '連線失敗：' + e.message);
        } finally {
          publishBtn.disabled = false;
          publishBtn.textContent = '送出發文';
        }
      });

      function showMsg(type, text) {
        publishMsg.className = 'msg ' + type;
        publishMsg.textContent = text;
        publishMsg.hidden = false;
        publishMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }

      // ===== 刪除文章 =====
      const deleteBtn = document.getElementById('delete-btn');
      const deleteMsg = document.getElementById('delete-msg');

      deleteBtn.addEventListener('click', async () => {
        const slug = document.getElementById('delete-slug').value.trim();
        if (!slug) { showDeleteMsg('err', '請填入要刪除的文章檔名'); return; }
        if (!confirm(`確定要刪除「${slug}」這篇文章嗎？這個動作無法復原。`)) return;

        try {
          deleteBtn.disabled = true;
          deleteBtn.textContent = '刪除中…';
          const res = await fetch('/api/delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              password: sessionStorage.getItem(PW_KEY) || '',
              slug,
            }),
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok) { showDeleteMsg('err', data.error || `刪除失敗（HTTP ${res.status}）`); return; }
          showDeleteMsg('ok', `「${slug}」已刪除 ✅ 約 1 分鐘後從網站消失。`);
          document.getElementById('delete-slug').value = '';
        } catch (e) {
          showDeleteMsg('err', '連線失敗：' + e.message);
        } finally {
          deleteBtn.disabled = false;
          deleteBtn.textContent = '確認刪除';
        }
      });

      function showDeleteMsg(type, text) {
        deleteMsg.className = 'msg ' + type;
        deleteMsg.textContent = text;
        deleteMsg.hidden = false;
      }

      // ===== 即時預覽 =====
      const tabEdit    = document.getElementById('tab-edit');
      const tabPreview = document.getElementById('tab-preview');
      const editCol    = document.getElementById('edit-col');
      const previewCol = document.getElementById('preview-col');
      const previewPane = document.getElementById('preview-pane');

      // 手機版 tab 切換
      tabEdit.addEventListener('click', () => {
        editCol.hidden = false;
        previewCol.hidden = true;
        tabEdit.classList.add('tab-active');
        tabPreview.classList.remove('tab-active');
      });

      tabPreview.addEventListener('click', () => {
        editCol.hidden = true;
        previewCol.hidden = false;
        tabEdit.classList.remove('tab-active');
        tabPreview.classList.add('tab-active');
        renderPreview();
      });

      // 即時預覽：輸入後 400ms debounce
      let previewTimer = null;
      document.getElementById('body').addEventListener('input', () => {
        clearTimeout(previewTimer);
        previewTimer = setTimeout(renderPreview, 400);
      });

      function preprocessBlocks(md) {
        // :::sunny
        md = md.replace(/:::sunny\n([\s\S]*?):::/g, (_, content) => {
          const paras = content.trim().split(/\n\n+/).map(p =>
            '<p>' + p.trim().replace(/\n/g, '<br>') + '</p>'
          ).join('');
          return `<div class="sunny-note"><div class="note-title">Sunny 營養師的小叮嚀</div>${paras}</div>`;
        });
        // :::product
        md = md.replace(/:::product\n([\s\S]*?):::/g, (_, content) => {
          const props = {};
          content.split('\n').forEach(line => {
            const m = line.match(/^(\w+):\s*(.+)$/);
            if (m) props[m[1]] = m[2].trim();
          });
          const img = props.image
            ? `<img src="${props.image}" alt="${props.title || ''}">`
            : '';
          return `<div class="product-card"><div class="product-card-inner">` +
            `<div class="product-card-image">${img}</div>` +
            `<div class="product-card-content">` +
            `<span class="product-card-tag">Sunny 營養師自家開發</span>` +
            `<h4>${props.title || ''}</h4>` +
            `<p>${props.description || ''}</p>` +
            `<a class="product-card-cta" href="#">看看價格與組合 →</a>` +
            `</div></div></div>`;
        });
        // :::related
        md = md.replace(/:::related\{slug=([^}]+)\}\n([\s\S]*?):::/g, (_, slug, content) => {
          const title = content.trim();
          return `<a class="related-link" href="/posts/${slug}">` +
            `<span class="related-label">延伸閱讀</span>` +
            `<span class="related-title">${title}</span></a>`;
        });
        return md;
      }

      function renderPreview() {
        const raw = document.getElementById('body').value;
        if (!raw.trim()) {
          previewPane.innerHTML = '<p style="color:#aaa;text-align:center;padding:48px 0;font-size:15px;">還沒有內文，切回編輯貼上 markdown 後再預覽。</p>';
          return;
        }
        if (typeof marked === 'undefined') {
          previewPane.innerHTML = '<p style="color:#aaa">預覽功能載入中，請稍後再點一次預覽。</p>';
          return;
        }
        previewPane.innerHTML = marked.parse(preprocessBlocks(raw));
      }
    </script>
  </body>
</html>
