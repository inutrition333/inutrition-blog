---
/**
 * PostCard — 文章列表卡片（左圖右文）
 *
 * 首頁、分類頁的文章列表都用這個。
 * 桌機：左圖（180px）+ 右文。手機：上下堆疊。
 * 沒有 heroImage 的文章會顯示漸層底色當 placeholder。
 */

import type { CollectionEntry } from 'astro:content';

export interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, category, excerpt, heroImage, publishDate, readTime } = post.data;
const href = `/posts/${post.id}/`;

function formatDate(d: Date): string {
  return `${d.getFullYear()}/${String(d.getMonth() + 1).padStart(2, '0')}/${String(d.getDate()).padStart(2, '0')}`;
}
---

<a class="post-card" href={href}>
  <div
    class="post-card-image"
    style={
      heroImage
        ? `background-image: url('${heroImage}'); background-size: cover; background-position: center;`
        : undefined
    }
    aria-hidden="true"
  >
  </div>
  <div class="post-card-body">
    <div class="post-card-category">{category}</div>
    <h3 class="post-card-title">{title}</h3>
    <p class="post-card-excerpt">{excerpt}</p>
    <div class="post-card-meta">
      <span>{formatDate(publishDate)}</span>
      <span class="dot">・</span>
      <span>閱讀約 {readTime} 分鐘</span>
    </div>
  </div>
</a>

<style>
  .post-card {
    display: grid;
    /* 用 minmax(0, 1fr) 讓右側欄能夠收縮到比 max-content 還窄
       （否則中文長標題會撐爆 grid，文字超出 viewport） */
    grid-template-columns: 180px minmax(0, 1fr);
    gap: 20px;
    background: var(--color-card-bg);
    border-radius: 14px;
    padding: 16px;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 2px 12px var(--color-card-shadow);
    transition:
      transform 0.15s,
      box-shadow 0.2s;
  }
  .post-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(46, 40, 32, 0.12);
    text-decoration: none;
  }
  .post-card-image {
    aspect-ratio: 4 / 3;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--color-accent-light), #eddcc8);
    align-self: start;
  }
  .post-card-body {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0; /* 讓長標題能換行而不撐爆 grid */
  }
  .post-card-category {
    font-size: 12px;
    letter-spacing: 2px;
    color: var(--color-accent-dark);
    font-weight: 500;
  }
  .post-card-title {
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.5;
    margin: 0;
    /* 中文沒空格無法靠空白斷行，強制任意位置可斷 */
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .post-card-excerpt {
    font-size: 14px;
    color: var(--color-text-light);
    line-height: 1.7;
    margin: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
    /* 限制顯示行數 */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-card-meta {
    font-size: 12px;
    color: var(--color-text-light);
    margin-top: 4px;
  }
  .post-card-meta .dot {
    margin: 0 4px;
    opacity: 0.6;
  }

  /* 手機 / 平板：圖片改放上方，整張卡上下堆疊 */
  @media (max-width: 768px) {
    .post-card {
      /* minmax(0, 1fr) 而非單獨 1fr——後者 min size 是 max-content
         導致中文長標題撐爆容器、文字超出 viewport */
      grid-template-columns: minmax(0, 1fr);
      gap: 12px;
      padding: 14px;
    }
    .post-card-image {
      aspect-ratio: 16 / 9;
    }
    .post-card-title {
      font-size: 17px;
    }
    .post-card-excerpt {
      font-size: 13px;
    }
  }
</style>
