---
/**
 * CategorySidebar — 首頁 / 分類頁的左側分類側欄
 *
 * 直式列表，每項顯示「分類名稱（文章數）」。
 * 當前所在分類用綠底白字 highlight；其他項目白底深字 hover 變淡綠。
 *
 * 手機版（≤ 900px）：改成水平捲動的標籤列，節省垂直空間。
 */

import type { CategoryItem, CategoryName } from '../lib/categories';

export interface Props {
  items: CategoryItem[];
  /** 目前所在分類名稱，例如「腸胃保健」；首頁傳「全部文章」 */
  current: CategoryName;
}

const { items, current } = Astro.props;
---

<aside class="category-sidebar" aria-label="分類">
  <div class="category-sidebar-title">分類</div>
  <nav class="category-list">
    {
      items.map((item) => {
        const isActive = item.name === current;
        return (
          <a
            href={item.href}
            class:list={['category-item', { 'is-active': isActive }]}
            aria-current={isActive ? 'page' : undefined}
          >
            <span class="category-name">{item.name}</span>
            <span class="category-count">({item.count})</span>
          </a>
        );
      })
    }
  </nav>
</aside>

<style>
  .category-sidebar {
    background: var(--color-card-bg);
    border-radius: 14px;
    padding: 20px 18px;
    box-shadow: 0 2px 12px var(--color-card-shadow);
  }
  .category-sidebar-title {
    font-size: 12px;
    letter-spacing: 4px;
    color: var(--color-text-light);
    font-weight: 500;
    margin-bottom: 14px;
    text-align: center;
  }
  .category-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .category-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 14px;
    border-radius: 8px;
    text-decoration: none;
    color: var(--color-text);
    font-size: 15px;
    transition:
      background 0.15s,
      color 0.15s;
  }
  .category-item:hover {
    background: var(--color-accent-light);
    color: var(--color-accent-dark);
    text-decoration: none;
  }
  .category-item.is-active {
    background: var(--color-accent);
    color: #fff;
    font-weight: 500;
  }
  .category-item.is-active:hover {
    background: var(--color-accent-dark);
    color: #fff;
  }
  .category-count {
    font-size: 13px;
    opacity: 0.75;
  }

  /* 手機版：sidebar 從左側欄改成上方水平捲動標籤列 */
  @media (max-width: 768px) {
    .category-sidebar {
      padding: 14px 14px 12px;
    }
    .category-sidebar-title {
      text-align: left;
      margin-bottom: 10px;
    }
    .category-list {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 6px;
    }
    .category-item {
      flex: 1 1 auto;
      padding: 8px 12px;
      font-size: 14px;
      text-align: center;
      white-space: nowrap;
    }
  }
</style>
